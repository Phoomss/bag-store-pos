{
    "name": "bag-pos/bag-pos",
    "description": "Bag Store POS and Inventory Management System",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
